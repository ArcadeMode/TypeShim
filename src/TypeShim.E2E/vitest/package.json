{
  "name": "@typeshim/e2e-vitest",
  "private": true,
  "type": "module",
  "scripts": {
    "test:node": "cross-env VITE_BROWSER_MODE=false vitest run",
    "test:browser": "cross-env VITE_BROWSER_MODE=true vitest run",
    "bench:node": "cross-env NODE_OPTIONS=--expose-gc && vitest bench --run",
    "initialize": "dotnet publish ../TypeShim.E2E.Wasm -c Release && node ./scripts/patch-warnings.mjs && npm ci && ./node_modules/.bin/playwright install chromium --with-deps",
    "build": "dotnet publish ../TypeShim.E2E.Wasm -c Release && node ./scripts/patch-warnings.mjs"
  },
  "dependencies": {
    "@typeshim/e2e-wasm-lib": "file:../wasm-lib-publish/wwwroot"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vitest/browser": "^4.1.9",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
